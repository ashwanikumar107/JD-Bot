# Copy this file to .env and fill in your values

# ── Telegram Bot Token (from @BotFather) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Scoring Thresholds ────────────────────────────────────────────────────────
# Scores below this threshold trigger detailed suggestions
SCORE_THRESHOLD=70

# ── NLP Backend  (tfidf | sbert) ─────────────────────────────────────────────
# Use 'sbert' for higher accuracy (requires sentence-transformers + more RAM)
# Use 'tfidf' for lightweight / fast deployment
NLP_BACKEND=tfidf

# ── Output Directory ──────────────────────────────────────────────────────────
OUTPUT_DIR=output
